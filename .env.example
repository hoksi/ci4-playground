#--------------------------------------------------------------------
# CI4 Playground — 환경 설정 예시
#
# 사용 방법:
#   cp .env.example .env
# 그런 다음 .env 파일에서 필요한 값을 수정하세요.
#--------------------------------------------------------------------

#--------------------------------------------------------------------
# ENVIRONMENT
# development | testing | production
#--------------------------------------------------------------------

CI_ENVIRONMENT = production

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

# 실제 서버 URL로 변경하세요 (끝에 슬래시 없음)
app.baseURL = 'https://your-domain.com'

# HTTPS 강제 여부 (공개 서버 권장)
# app.forceGlobalSecureRequests = true

# CSRF 보호 활성화 (기본 활성화)
# app.CSPEnabled = false

#--------------------------------------------------------------------
# DATABASE (SQLite — 별도 설치 불필요)
#--------------------------------------------------------------------

database.default.DBDriver = SQLite3
database.default.database = database.db

#--------------------------------------------------------------------
# ENCRYPTION KEY
# 생성 방법: php spark key:generate
#--------------------------------------------------------------------

# encryption.key = hex2bin(...)

#--------------------------------------------------------------------
# SESSION
#--------------------------------------------------------------------

# session.driver = 'CodeIgniter\Session\Handlers\FileHandler'
# session.savePath = null
# session.expiration = 7200
# session.cookieSecure = true

#--------------------------------------------------------------------
# LOGGER (production에서는 ERROR 이상만 기록)
#--------------------------------------------------------------------

# logger.threshold = 4

#--------------------------------------------------------------------
# 데이터 리셋 자동화 (cron 등록 예시)
# 0 3 * * * cd /var/www/playground && php spark playground:reset --quiet >> writable/logs/reset.log 2>&1
#--------------------------------------------------------------------
